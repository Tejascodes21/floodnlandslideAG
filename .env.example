# =========================================================================
# GeoShield AI — Environment Variable Configurations
# =========================================================================
# Copy this file to '.env' (for backend) and config files as required.

# --- Backend Settings ---
# JWT token signing secret key
JWT_SECRET=4749f7b13a36db5ee00388f6b9c9f7fe7e61e0bbcd33f81e6dc8b09339e14a1a

# Database Connection (FastAPI auto-detects Postgres / SQLite)
DATABASE_URL=sqlite:///./geoshield.db

# Live Weather Integrations (OpenWeather API key)
OPENWEATHER_API_KEY=mock_weather_key_geoshield

# Google Earth Engine Project Identifier
GEE_PROJECT=mock-gee-project

# --- Frontend Settings ---
# GeoShield Gateway Base URL
VITE_API_BASE_URL=http://localhost:8000
